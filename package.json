{
  "name": "leapswap",
  "version": "0.1.0",
  "private": true,
  "description": "LeapSwap — configurable cross-chain swap & bridge widget SDK",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "clean": "pnpm -r --filter './packages/**' clean",
    "dev": "pnpm --filter openocean-example dev",
    "dev:kyberswap": "pnpm --filter kyberswap-example dev",
    "publish:dry": "bash scripts/publish-packages.sh",
    "publish:packages": "bash scripts/publish-packages.sh --yes",
    "check:types": "pnpm -r --parallel --filter './packages/**' check:types",
    "check": "biome check"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "cpy-cli": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "overrides": {
      "bs58": ">=4.0.1"
    }
  },
  "packageManager": "pnpm@10.6.4",
  "engines": {
    "node": ">=20"
  }
}
