{
  "name": "@leapswap/business-integrator",
  "version": "0.1.0",
  "description": "Business integrator swap data provider for @leapswap/widget",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "scripts": {
    "check:types": "tsc --noEmit",
    "test": "vitest run"
  },
  "author": "leapswap",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "!src/**/*.test.ts"
  ],
  "dependencies": {
    "@leapswap/widget-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
